{
  "name": "librechat-prom-exporter",
  "version": "0.7.0",
  "description": "Prometheus exporter for LibreChat metrics",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "lint": "eslint . --ext .ts --config eslint.config.mjs",
    "lint:fix": "eslint . --ext .ts --config eslint.config.mjs --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix --config eslint.config.mjs"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubentalstra/librechat-prom-exporter.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/rubentalstra/librechat-prom-exporter/issues"
  },
  "homepage": "https://github.com/rubentalstra/librechat-prom-exporter#readme",
  "dependencies": {
    "@librechat/data-schemas": "^0.0.51",
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "ipaddr.js": "^2.4.0",
    "jose": "^6.2.3",
    "librechat-data-provider": "^0.8.502",
    "mongoose": "^8.24.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "mongodb-memory-server": "^11.1.0",
    "nock": "^15.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}

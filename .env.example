# MongoDB connection string for external database
MONGO_URI=mongodb://host.docker.internal:27017/librechat

# Application port (optional, if used in your app)
PORT=9087

# Time in ms to refresh metrics
REFRESH_INTERVAL=30000

# Time in ms to refresh the (much heavier) advanced metrics.
# Defaults to REFRESH_INTERVAL * 10 if unset.
ADVANCED_REFRESH_INTERVAL=300000

# Mongo connection pool size used by mongoose.connect.
MONGO_POOL_SIZE=50

# Set to true to enable verbose timing logs:
#   - per-scrape start/duration logs
#   - per-section [adv-section] timings inside the advanced scrape
# Errors and skipped-tick warnings are always logged regardless of this flag.
# Accepts: true/false (canonical), also 1/0, yes/no, on/off (case-insensitive).
LOG_TIMINGS=false

# Emit per-user `email`-labeled metrics. UNBOUNDED CARDINALITY:
# one time series per user, retained by prom-client for the process
# lifetime. Default false. Only enable on small / single-tenant deployments
# where you want per-user dashboards. The corresponding `_by_email_domain`
# metrics remain enabled regardless of this flag.
# Accepts: true/false (canonical), also 1/0, yes/no, on/off (case-insensitive).
# Affected metrics:
#   librechat_transaction_cost_by_user{email}
#   librechat_transaction_token_sum_by_model_user{model,tokenType,email}
#   librechat_agent_usage_by_user_count{agent,email}
EMIT_PER_USER_METRICS=false
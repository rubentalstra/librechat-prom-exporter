{
  "ci": {
    "collect": {
      "staticDistDir": "./build",
      "url": [
        "http://localhost/librechat-prom-exporter/",
        "http://localhost/librechat-prom-exporter/docs/intro",
        "http://localhost/librechat-prom-exporter/docs/reference/environment-variables",
        "http://localhost/librechat-prom-exporter/docs/contributing/architecture"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.85 }],
        "categories:seo": ["error", { "minScore": 0.9 }],
        "uses-text-compression": "off",
        "csp-xss": "off"
      }
    },
    "upload": { "target": "temporary-public-storage" }
  }
}
